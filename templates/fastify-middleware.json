{
	"name": "Fastify Middleware",
	"description": "Template for generating a Fastify middleware",
	"type": "middleware",
	"template": [
		"import { FastifyRequest, FastifyReply } from 'fastify';",
		"",
		"/**",
		" * Runs the {{fileNamePascalCase}} middleware.",
		" */",
		"export async function {{fileNamePascalCase}}(request: FastifyRequest, reply: FastifyReply): Promise<void> {",
		"  const headerValue = request.headers['x-request-id'];",
		"  const requestId = typeof headerValue === 'string' && headerValue.trim()",
		"    ? headerValue.trim()",
		"    : `${Date.now()}-${Math.random().toString(16).slice(2)}`;",
		"",
		"  reply.header('x-request-id', requestId);",
		"}"
	]
}
