{
	"name": "Express Controller",
	"description": "Template for generating an Express.js controller",
	"type": "controller",
	"template": [
		"import { Request, Response } from 'express';",
		"",
		"type Create{{fileNamePascalCase}}Body = {",
		"  name?: string;",
		"};",
		"",
		"class {{fileNamePascalCase}}{{fileTypeName}}Service {",
		"  public createResource(name: string): { id: string; name: string } {",
		"    const normalizedName = name.trim();",
		"",
		"    if (!normalizedName) {",
		"      throw new Error('Name is required');",
		"    }",
		"",
		"    return {",
		"      id: `${Date.now()}`,",
		"      name: normalizedName",
		"    };",
		"  }",
		"}",
		"",
		"/**",
		" * Handles {{fileNamePascalCase}} HTTP requests.",
		" */",
		"export class {{fileNamePascalCase}}{{fileTypeName}} {",
		"  private static readonly service = new {{fileNamePascalCase}}{{fileTypeName}}Service();",
		"",
		"  public static async handle(request: Request<unknown, unknown, Create{{fileNamePascalCase}}Body>, response: Response): Promise<void> {",
		"    try {",
		"      const name = request.body.name?.trim() || '';",
		"",
		"      if (!name) {",
		"        response.status(400).json({ error: 'Name is required' });",
		"        return;",
		"      }",
		"",
		"      const result = this.service.createResource(name);",
		"      response.status(201).json(result);",
		"    } catch (error: unknown) {",
		"      const message = error instanceof Error ? error.message : 'Unexpected server error';",
		"      response.status(500).json({ error: message });",
		"    }",
		"  }",
		"}"
	]
}
