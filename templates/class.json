{
	"name": "Class Template",
	"description": "Template for generating a TypeScript class",
	"type": "class",
	"template": [
		"/**",
		" * Manages {{fileNamePascalCase}}{{fileTypeName}} items.",
		" */",
		"export class {{fileNamePascalCase}}{{fileTypeName}} {",
		"  private readonly items: string[];",
		"",
		"  constructor(initialItems: string[] = []) {",
		"    this.items = [...initialItems];",
		"  }",
		"",
		"  public addItem(item: string): void {",
		"    const normalizedItem = item.trim();",
		"",
		"    if (!normalizedItem) {",
		"      throw new Error('Item is required');",
		"    }",
		"",
		"    this.items.push(normalizedItem);",
		"  }",
		"",
		"  public getItems(): string[] {",
		"    return [...this.items];",
		"  }",
		"}"
	]
}
