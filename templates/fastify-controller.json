{
	"name": "Fastify Controller",
	"description": "Template for generating a Fastify controller",
	"type": "controller",
	"template": [
		"import { FastifyReply, FastifyRequest } from 'fastify';",
		"",
		"type Create{{fileNamePascalCase}}Body = {",
		"  name?: string;",
		"};",
		"",
		"class {{fileNamePascalCase}}Service {",
		"  public createResource(name: string): { id: string; name: string } {",
		"    const normalizedName = name.trim();",
		"",
		"    if (!normalizedName) {",
		"      throw new Error('Name is required');",
		"    }",
		"",
		"    return {",
		"      id: `${Date.now()}`,",
		"      name: normalizedName",
		"    };",
		"  }",
		"}",
		"",
		"const service = new {{fileNamePascalCase}}Service();",
		"",
		"/**",
		" * Handles {{fileNamePascalCase}} HTTP requests.",
		" */",
		"export async function {{fileNamePascalCase}}(request: FastifyRequest<{ Body: Create{{fileNamePascalCase}}Body }>, reply: FastifyReply): Promise<void> {",
		"  try {",
		"    const name = request.body.name?.trim() || '';",
		"",
		"    if (!name) {",
		"      reply.status(400).send({ error: 'Name is required' });",
		"      return;",
		"    }",
		"",
		"    const result = service.createResource(name);",
		"    reply.status(201).send(result);",
		"  } catch (error: unknown) {",
		"    const message = error instanceof Error ? error.message : 'Unexpected server error';",
		"    reply.status(500).send({ error: message });",
		"  }",
		"}"
	]
}
